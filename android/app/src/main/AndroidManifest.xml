<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required by the sync job's VPN network constraint (ADR-0009):
         JobScheduler rejects connectivity-constrained jobs without it.
         Verified on-device; Robolectric does not enforce this. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Special permission: the owner grants it once via
         Settings > Apps > Special app access > Usage access. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <!-- Required by JobInfo.setPersisted(); no boot receiver exists or
         is ever added (ADR-0007). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Lets the in-app button raise the "ignore battery optimizations"
         dialog. Without the exemption, standby buckets quota-starve the
         15-min jobs once the app is never opened (LAB_NOTES 2026-07-12).
         Play would flag this permission; irrelevant for a sideloaded
         personal app. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- usesCleartextTraffic: the server is plain http inside the
         tailnet (no TLS by design; the tailnet is the perimeter). -->
    <application
        android:label="are-you-up"
        android:usesCleartextTraffic="true">
        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".SampleJob"
            android:permission="android.permission.BIND_JOB_SERVICE" />
    </application>
</manifest>
